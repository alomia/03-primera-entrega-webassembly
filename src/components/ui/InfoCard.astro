---
interface Props {
  title: string;
  description: string;
  icon: any
}

const { title, description, icon: Icon } = Astro.props;
---

<div class="card card-border bg-base-200">
  <div class="card-body space-y-3">
    <div class="badge badge-soft badge-primary badge-lg px-2 py-5">
      <Icon />
    </div>
    <h2 class="card-title">{title}</h2>
    <p class="text-base-content/70">{description}</p>
  </div>
</div>
